name: Safety GaurdRail For Indic Languages 

python_env: python_env.yaml
entry_points:
  train:
    parameters:
      learning_rate: {type: float, default: 1e-4}
      batch_size: {type: int, default: 32}
      num_epochs: {type: int, default: 30}
      dropout: {type: float, default: 0.4}
    command: "python3 src/train.py --learning_rate={learning_rate} --batch_size={batch_size} --num_epochs={num_epochs} --dropout={dropout}"
